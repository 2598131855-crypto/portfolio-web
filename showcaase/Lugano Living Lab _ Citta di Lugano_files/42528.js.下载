      delay: scaleTime(4),
      ease: "power2.inOut",
    });
  }

  // Animate the preload eyebrow titles X movement (after FLIP)
  if (eyebrowElements.length >= 3) {
    const eyebrowXDuration = scaleTime(0.6) * 1.25;
    gsap.to("[data-target='preload-eyebrow']", {
      x: "0%",
      duration: eyebrowXDuration,
      delay: scaleTime(4.5), // After FLIP animation completes
      ease: "power2.inOut",
    });
  }

  gsap.to(".digit", {
    top: "-3em",
    stagger: { amount: scaleTime(0.2) },
    delay: scaleTime(4),
    duration: scaleTime(0.8),
    ease: "power4.inOut",
  });

