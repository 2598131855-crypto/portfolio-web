// Simple retry logic for mobile initialization
function mobileRetryInit(initFunction, maxRetries = 2) {
  const isMobile = window.innerWidth <= 991;

  if (!isMobile) {
    // Desktop: initialize immediately
    initFunction();
    return;
  }

  // Mobile: try with retries
  let attempts = 0;

  function attemptInit() {
    try {
      initFunction();
    } catch (error) {
      attempts++;
      if (attempts < maxRetries) {
        setTimeout(attemptInit, 1000);
      }
    }
  }

  attemptInit();
}

