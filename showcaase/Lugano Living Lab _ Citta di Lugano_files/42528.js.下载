  const pillContainer = document.querySelector('.filter__tags');

  // If no filter elements exist, exit early
  if (items.length === 0) {
    return;
  }

  const transitionDelay = 300;

  let activeFilters = {
    stato: new Set(['all']),
    sostenitori: new Set(['all'])
  };
  let selectedTags = [];
  let isFiltering = false;

  // Build master set of searchable terms (tags + titles, lowercase)
  const searchSet = new Set();
  items.forEach(item => {
    const tagElements = item.querySelectorAll('[data-filter-tags]');
    tagElements.forEach(tagElement => {
      const txt = tagElement.textContent || '';
      txt.split(/\s+/).forEach(raw => {
        const t = raw.replace(/^#/, '').toLowerCase().trim();
        if (t) searchSet.add(t);
      });
    });

    const titleText = item.querySelector('.item-list__title .h5')?.textContent || '';
    const normalizedTitle = titleText.toLowerCase().trim();
    if (normalizedTitle) {
      searchSet.add(normalizedTitle);
      normalizedTitle.split(/\s+/).forEach(word => {
        const cleanWord = word.trim();
        if (cleanWord) searchSet.add(cleanWord);
      });
    }
  });

  // Build sets of available "sostenitori" and "stato"
  const availableSostenitori = new Set();
  const availableStato = new Set();
  items.forEach(item => {
    item.querySelectorAll('[data-sostenitori-item]').forEach(s => {
      availableSostenitori.add(s.getAttribute('data-sostenitori-item'));
    });
    const sVal = item.getAttribute('data-stato-item');
    if (sVal) availableStato.add(sVal);
  });

  // Hide checkboxes for any value not present in the items
  sostCheckboxes.forEach(cb => {
    const target = cb.getAttribute('data-sostenitori-target');
    const wrapper = cb.closest('.filter__dropdown-item');
    if (!availableSostenitori.has(target) && wrapper) {
      wrapper.style.display = 'none';
    }
  });
  statoCheckboxes.forEach(cb => {
    const target = cb.getAttribute('data-stato-target');
    const wrapper = cb.closest('.filter__dropdown-item');
    if (!availableStato.has(target) && wrapper) {
      wrapper.style.display = 'none';
    }
  });

  // Set every item initially to active
  items.forEach(item => {
    item.setAttribute('data-filter-status', 'active');
    item.setAttribute('aria-hidden', 'false');
  });

  // Initially hide the reset button since no filters are active
  if (resetButton) {
    resetButton.classList.add('filter--hide');
  }

  // Helper: update a single item's "active" vs "not-active"
  const updateStatus = (el, shouldBeActive) => {
    el.setAttribute('data-filter-status', shouldBeActive ? 'active' : 'not-active');
    el.setAttribute('aria-hidden', shouldBeActive ? 'false' : 'true');
  };

  // Helper: update the small "(n) count" inside each dropdown and reset button visibility
  const updateFilterAmount = (filterType) => {
    const dropdown = document.querySelector(
      `.filter__dropdown[data-filter-type="${filterType}"]`);
    if (!dropdown) return;
    const amountSpan = dropdown.querySelector('[data-filter-amount]');
    if (!amountSpan) return;

    const count = activeFilters[filterType].has('all') ? 0 : activeFilters[filterType].size;

    if (count > 0) {
      amountSpan.textContent = `(${count})`;
      gsap.to(amountSpan, { opacity: 1, duration: 0.3, ease: 'power2.out' });
    } else {
      gsap.to(amountSpan, { opacity: 0, duration: 0.3, ease: 'power2.out' });
    }

    // Check if any filters are active and show/hide reset button
    const hasActiveFilters = !activeFilters.stato.has('all') || !activeFilters.sostenitori.has(
      'all') || selectedTags.length > 0;
    if (resetButton) {
      if (hasActiveFilters) {
        resetButton.classList.remove('filter--hide');
      } else {
        resetButton.classList.add('filter--hide');
      }
    }
  };

  // Helper: update reset button visibility (called when tags change)
  const updateResetButtonVisibility = () => {
    const hasActiveFilters = !activeFilters.stato.has('all') || !activeFilters.sostenitori.has(
      'all') || selectedTags.length > 0;
    if (resetButton) {
      if (hasActiveFilters) {
        resetButton.classList.remove('filter--hide');
      } else {
        resetButton.classList.add('filter--hide');
      }
    }
  };

  // Helper: show/hide the "no results" empty-state panel
  const checkEmptyState = () => {
    const activeCount = document.querySelectorAll('.item-list__item[data-filter-status="active"]')
      .length;
    if (activeCount === 0) {
      if (emptyStateEl && emptyStateEl.style.display === 'none') {
        emptyStateEl.style.display = 'block';
        gsap.fromTo(emptyStateEl, { opacity: 0 }, {
          opacity: 1,
          duration: 0.3,
          ease: 'power2.out'
        });
      }
    } else {
      if (emptyStateEl && emptyStateEl.style.display !== 'none') {
        emptyStateEl.style.display = 'none';
        emptyStateEl.style.opacity = '0';
      }
    }
  };

  // Helper: instant scroll via Lenis to #section-filter with offset -100
  const scrollToFilter = () => {
    if (!filterSection || typeof lenis === 'undefined') return;
    lenis.scrollTo("#section-filter", {
      offset: -100,
      duration: 1.2,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t))
    });
  };

  // RESET BUTTON logic
  const doResetFilters = () => {
    scrollToFilter();
    if (isFiltering) return;
    isFiltering = true;

    // Close any open dropdowns
    dropdowns.forEach(dropdown => {
      if (dropdown.classList.contains('is-open')) {
        const list = dropdown.querySelector('.filter__dropdown-list');
        const arrow = dropdown.querySelector('.filter__dropdown-svg');
        gsap.timeline()
          .to(list, { height: 0, opacity: 0, duration: 0.3, ease: 'power2.inOut' })
          .set(list, { display: 'none' })
          .to(arrow, { rotation: 0, duration: 0.3, ease: 'power2.inOut' });
        dropdown.classList.remove('is-open');
        dropdown.isOpen = false;
      }
    });

    // Uncheck all checkboxes
    [...statoCheckboxes, ...sostCheckboxes].forEach(cb => cb.checked = false);
    if (mainEventToggle) mainEventToggle.checked = false;

    // Reset filter sets to "all"
    activeFilters.stato = new Set(['all']);
    activeFilters.sostenitori = new Set(['all']);

    // Reset tag filters
    selectedTags = [];
    if (pillContainer) {
      pillContainer.innerHTML = '';
    }
    if (tagInput) {
      tagInput.value = '';
      // Clear ghost text
      const suggestionDiv = tagInput.parentElement?.querySelector('.suggestion');
      if (suggestionDiv) {
        suggestionDiv.textContent = '';
      }
    }

    // Update the little badge counts
    updateFilterAmount('stato');
    updateFilterAmount('sostenitori');

    // Fade all items back in
    items.forEach(item => {
      if (item.getAttribute('data-filter-status') === 'active') {
        item.setAttribute('data-filter-status', 'transition-out');
      }
      item.timeoutId = setTimeout(() => {
        updateStatus(item, true);
        item.timeoutId = null;
      }, transitionDelay);
    });

    // After the transition, re-enable filtering and hide empty state
    setTimeout(() => {
      isFiltering = false;
      checkEmptyState();
    }, transitionDelay + 50);
  };

  // Event listeners for reset buttons
  if (resetButton) {
    resetButton.addEventListener('click', (e) => {
      e.preventDefault();
      doResetFilters();
    });
  }
  if (emptyStateBtn) {
    emptyStateBtn.addEventListener('click', (e) => {
      e.preventDefault();
      doResetFilters();
    });
  }

  // Main event toggle logic (if exists)
  if (mainEventToggle) {
    mainEventToggle.addEventListener('change', () => {
      scrollToFilter();
      if (isFiltering) return;
      isFiltering = true;

      const onlyMain = mainEventToggle.checked;
      items.forEach(item => {
        const anchor = item.querySelector('a[data-sostenitori-item]');
        const sostenitoriValue = anchor?.getAttribute('data-sostenitori-item');
        // Consider both "Yes" and "main-event" as main events
        const isMainEvt = sostenitoriValue === 'Yes' || sostenitoriValue === 'main-event';

        const statoVal = item.getAttribute('data-stato-item');
        const sostList = Array.from(item.querySelectorAll('[data-sostenitori-item]'))
          .map(el => el.getAttribute('data-sostenitori-item'));

        const matchesStato = activeFilters.stato.has('all') || activeFilters.stato.has(
          statoVal);
        const matchesSost = activeFilters.sostenitori.has('all') ||
          sostList.some(s => activeFilters.sostenitori.has(s));
        const matchesMain = !onlyMain || isMainEvt;

        const shouldBeActive = matchesStato && matchesSost && matchesMain;
        const currStatus = item.getAttribute('data-filter-status');

        if (currStatus === 'active') {
          item.setAttribute('data-filter-status', 'transition-out');
          item.timeoutId = setTimeout(() => {
            updateStatus(item, shouldBeActive);
            item.timeoutId = null;
          }, transitionDelay);
        } else {
          item.timeoutId = setTimeout(() => {
            updateStatus(item, shouldBeActive);
            item.timeoutId = null;
          }, transitionDelay);
        }
      });

      setTimeout(() => {
        isFiltering = false;
        checkEmptyState();
      }, transitionDelay + 50);
    });
  }

  // Handle checkbox changes
  [...statoCheckboxes, ...sostCheckboxes].forEach(checkbox => {
    checkbox.addEventListener('change', () => {
      scrollToFilter();
      if (isFiltering) return;
      isFiltering = true;

      const filterType = checkbox.hasAttribute('data-stato-target') ? 'stato' :
        'sostenitori';
      const target = checkbox.getAttribute(`data-${filterType}-target`);

      handleFilter(filterType, target, checkbox.checked);

      setTimeout(() => {
        isFiltering = false;
        checkEmptyState();
      }, transitionDelay + 50);
    });
  });

  // Core filter function
  function handleFilter(filterType, target, isChecked) {
    // Clear any pending timeouts
    items.forEach(item => {
      if (item.timeoutId) {
        clearTimeout(item.timeoutId);
        item.timeoutId = null;
      }
    });

    // Manage activeFilters
    if (isChecked) {
      if (activeFilters[filterType].has('all')) {
        activeFilters[filterType].clear();
      }
      activeFilters[filterType].add(target);
    } else {
      activeFilters[filterType].delete(target);
      if (activeFilters[filterType].size === 0) {
        activeFilters[filterType].add('all');
      }
    }

    updateFilterAmount(filterType);
    scrollToFilter();

    // Update each item's visibility
    items.forEach(item => {
      const anchor = item.querySelector('a[data-sostenitori-item]');
      const sostenitoriValue = anchor?.getAttribute('data-sostenitori-item');
      // Consider both "Yes" and "main-event" as main events
      const isMainEvt = sostenitoriValue === 'Yes' || sostenitoriValue === 'main-event';

      const statoVal = item.getAttribute('data-stato-item');
      const sostList = Array.from(item.querySelectorAll('[data-sostenitori-item]'))
        .map(el => el.getAttribute('data-sostenitori-item'));

      const matchesStato = activeFilters.stato.has('all') || activeFilters.stato.has(statoVal);
      const matchesSost = activeFilters.sostenitori.has('all') ||
        sostList.some(sost => activeFilters.sostenitori.has(sost));
      const matchesMain = !mainEventToggle?.checked || isMainEvt;

      // Search filtering (tag match OR title match)
      const tagElement = item.querySelector('[data-filter-tags]');
      const titleText = item.querySelector('.item-list__title .h5')?.textContent
        ?.toLowerCase().trim() || '';
      const titleWords = titleText.split(/\s+/).filter(Boolean);
      const matchesTags = selectedTags.length === 0 || (tagElement && selectedTags.every(
        tag => {
          const itemTags = tagElement.textContent || '';
          const itemTagList = itemTags.split(/\s+/).map(t => t.replace(/^#/, '')
            .toLowerCase());
          return itemTagList.includes(tag) || titleText === tag || titleWords.includes(tag);
        }));

      const shouldBeActive = matchesStato && matchesSost && matchesMain && matchesTags;
      const currentStatus = item.getAttribute('data-filter-status');

      if (currentStatus === 'active') {
        item.setAttribute('data-filter-status', 'transition-out');
        item.timeoutId = setTimeout(() => {
          updateStatus(item, shouldBeActive);
          item.timeoutId = null;
        }, transitionDelay);
      } else {
        item.timeoutId = setTimeout(() => {
          updateStatus(item, shouldBeActive);
          item.timeoutId = null;
        }, transitionDelay);
      }
    });
  }

  // Dropdown animation functionality
  dropdowns.forEach(dropdown => {
    const toggle = dropdown.querySelector('.filter__dropdown-toggle');
    const list = dropdown.querySelector('.filter__dropdown-list');
    const arrow = dropdown.querySelector('.filter__dropdown-svg');
    const itemsList = dropdown.querySelectorAll('.filter__dropdown-item');
    dropdown.isOpen = false;

    gsap.set(list, { opacity: 0, height: 0, overflow: 'hidden' });
    gsap.set(arrow, { rotation: 0 });

    // Hover effects for dropdown items
    itemsList.forEach(item => {
      item.addEventListener('mouseenter', () => {
        gsap.to(itemsList, { opacity: 0.5, duration: 0.3, ease: 'power2.out' });
        gsap.to(item, {
          opacity: 1,
          duration: 0.3,
          ease: 'power2.out',
          overwrite: true
        });
      });
      item.addEventListener('mouseleave', () => {
        gsap.to(itemsList, { opacity: 1, duration: 0.3, ease: 'power2.out' });
      });
    });

    const openDropdown = () => {
      gsap.set(list, { display: 'block', opacity: 0 });
      const height = list.scrollHeight;
      dropdown.classList.add('is-open');

      gsap.timeline()
        .set(list, { display: 'block' })
        .to(list, { height: height, opacity: 1, duration: 0.4, ease: 'power3.out' })
        .to(arrow, { rotation: 180, duration: 0.4, ease: 'power3.out' }, '<');

      dropdown.isOpen = true;
    };

    const closeDropdown = () => {
      dropdown.classList.remove('is-open');

      gsap.timeline()
        .to(list, { height: 0, opacity: 0, duration: 0.3, ease: 'power2.inOut' })
        .set(list, { display: 'none' })
        .to(arrow, { rotation: 0, duration: 0.3, ease: 'power2.inOut' }, '<');

      dropdown.isOpen = false;
    };

    toggle.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();

      // Close other dropdowns
      dropdowns.forEach(otherDropdown => {
        if (otherDropdown !== dropdown && otherDropdown.isOpen) {
          const otherList = otherDropdown.querySelector('.filter__dropdown-list');
          const otherArrow = otherDropdown.querySelector('.filter__dropdown-svg');
          otherDropdown.classList.remove('is-open');

          gsap.timeline()
            .to(otherList, {
              height: 0,
              opacity: 0,
              duration: 0.3,
              ease: 'power2.inOut'
            })
            .set(otherList, { display: 'none' })
            .to(otherArrow, { rotation: 0, duration: 0.3, ease: 'power2.inOut' }, '<');

          otherDropdown.isOpen = false;
        }
      });

      // Toggle current dropdown
      dropdown.isOpen ? closeDropdown() : openDropdown();
    });
  });

  // ============================================================================
  // TAG SEARCH FUNCTIONALITY
  // ============================================================================

  // Render the "pills"
  function renderPills() {
    if (!pillContainer) return;

    pillContainer.innerHTML = '';
    selectedTags.forEach(tag => {
      const pill = document.createElement('div');
      pill.className = 'pill';
      pill.textContent = tag;
      const x = document.createElement('span');
      x.className = 'remove';
      x.textContent = '×';
      x.onclick = () => {
        selectedTags = selectedTags.filter(t => t !== tag);
        renderPills();
        updateResetButtonVisibility();
        applyAllFilters();
      };
      pill.appendChild(x);
      pillContainer.appendChild(pill);
    });
  }

  // Pin a tag (if valid + not already pinned)
  function addTag(tag) {
    tag = tag.toLowerCase().trim();

    if (!searchSet.has(tag)) {
      return;
    }

    if (selectedTags.includes(tag)) {
      return;
    }

    selectedTags.push(tag);
    renderPills();
    updateResetButtonVisibility();
    applyAllFilters();
  }

  // Apply all filters (checkbox + tag + main event)
  function applyAllFilters() {
    if (isFiltering) return;
    isFiltering = true;

    // Clear any pending timeouts
    items.forEach(item => {
      if (item.timeoutId) {
        clearTimeout(item.timeoutId);
        item.timeoutId = null;
      }
    });

    scrollToFilter();

    // Update each item's visibility
    items.forEach(item => {
      const anchor = item.querySelector('a[data-sostenitori-item]');
      const sostenitoriValue = anchor?.getAttribute('data-sostenitori-item');
      // Consider both "Yes" and "main-event" as main events
      const isMainEvt = sostenitoriValue === 'Yes' || sostenitoriValue === 'main-event';

      const statoVal = item.getAttribute('data-stato-item');
      const sostList = Array.from(item.querySelectorAll('[data-sostenitori-item]'))
        .map(el => el.getAttribute('data-sostenitori-item'));

      const matchesStato = activeFilters.stato.has('all') || activeFilters.stato.has(statoVal);
      const matchesSost = activeFilters.sostenitori.has('all') ||
        sostList.some(sost => activeFilters.sostenitori.has(sost));
      const matchesMain = !mainEventToggle?.checked || isMainEvt;

      // Search filtering (tag match OR title match)
      const tagElement = item.querySelector('[data-filter-tags]');
      const titleText = item.querySelector('.item-list__title .h5')?.textContent
        ?.toLowerCase().trim() || '';
      const titleWords = titleText.split(/\s+/).filter(Boolean);
      const matchesTags = selectedTags.length === 0 || (tagElement && selectedTags.every(
        tag => {
          const itemTags = tagElement.textContent || '';
          const itemTagList = itemTags.split(/\s+/).map(t => t.replace(/^#/, '')
            .toLowerCase());
          return itemTagList.includes(tag) || titleText === tag || titleWords.includes(tag);
        }));

      const shouldBeActive = matchesStato && matchesSost && matchesMain && matchesTags;
      const currentStatus = item.getAttribute('data-filter-status');

      if (currentStatus === 'active') {
        item.setAttribute('data-filter-status', 'transition-out');
        item.timeoutId = setTimeout(() => {
          updateStatus(item, shouldBeActive);
          item.timeoutId = null;
        }, transitionDelay);
      } else {
        item.timeoutId = setTimeout(() => {
          updateStatus(item, shouldBeActive);
          item.timeoutId = null;
        }, transitionDelay);
      }
    });

    setTimeout(() => {
      isFiltering = false;
      checkEmptyState();
    }, transitionDelay + 50);
  }

  // Initialize tag search functionality with ghost text autocomplete
  if (tagInput && pillContainer) {
    // Get the existing suggestion div
    const suggestionDiv = tagInput.parentElement?.querySelector('.suggestion');
    if (!suggestionDiv) {
      return;
    }

    // Force lowercase input and handle autocomplete
    tagInput.addEventListener('input', e => {
      // Force the input value to lowercase
      const currentValue = tagInput.value;
      const lowercaseValue = currentValue.toLowerCase();

      // Only update if the value actually changed (prevents cursor jumping)
      if (currentValue !== lowercaseValue) {
        const cursorPosition = tagInput.selectionStart;
        tagInput.value = lowercaseValue;
        // Restore cursor position
        tagInput.setSelectionRange(cursorPosition, cursorPosition);
      }

      const raw = lowercaseValue;
      const q = raw.replace(/^#/, '').toLowerCase();

      if (!q) {
        suggestionDiv.textContent = '';
        return;
      }

      // Find the shortest searchable term that starts with q
      const matches = Array.from(searchSet).filter(t => t.startsWith(q));

      if (!matches.length) {
        suggestionDiv.textContent = '';
        return;
      }

      const best = matches.sort((a, b) => a.length - b.length)[0];

      // Show full best match as ghost text
      suggestionDiv.textContent = best;
    });

    // Accept ghost suggestion with Tab or ArrowRight
    tagInput.addEventListener('keydown', e => {
      if ((e.key === 'Tab' || e.key === 'ArrowRight') && suggestionDiv.textContent) {
        e.preventDefault();
        tagInput.value = suggestionDiv.textContent;
        suggestionDiv.textContent = '';
      }
    });

    // Press Enter to pin the current tag (use autocomplete suggestion if available)
    tagInput.addEventListener('keydown', e => {
      if (e.key === 'Enter') {
        e.preventDefault();

        // If there's a suggestion, use that instead of the typed text
        let tag;
        if (suggestionDiv.textContent) {
          tag = suggestionDiv.textContent.trim().toLowerCase();
        } else {
          tag = tagInput.value.trim().replace(/^#/, '').toLowerCase();
        }

        if (tag) {
          addTag(tag);
          applyAllFilters();
        }
        tagInput.value = '';
        suggestionDiv.textContent = '';
      }
    });

    // Clear ghost text when input loses focus
    tagInput.addEventListener('blur', () => {
      // Small delay to allow for Enter key processing
      setTimeout(() => {
        suggestionDiv.textContent = '';
      }, 100);
    });
  }
}

