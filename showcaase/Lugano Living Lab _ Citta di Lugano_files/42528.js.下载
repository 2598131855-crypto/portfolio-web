      // On desktop, spread elements out
      gsap.set(eyebrowElements[0], { x: "400%" }); // First element starts from right
      gsap.set(eyebrowElements[1], { x: "0%" }); // Second element stays centered
      gsap.set(eyebrowElements[2], { x: "-400%" }); // Third element starts from left
    }

    // First animate Y with stagger (before FLIP)
