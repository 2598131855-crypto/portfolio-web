}

function initPageTransitions() {
  const transition = document.querySelector(".page-transition");
  const heroBg = document.querySelector(".hero--bg");
  const heroImg = document.querySelector(".hero__img");

  const enterTL = gsap.timeline({ defaults: { ease: "power2.out" } });

  // ─────────────────────────────────────────────────────────────
  // 1. ENTRANCE ANIMATION
  // ─────────────────────────────────────────────────────────────

  if (transition) {
    enterTL.to(transition, { autoAlpha: 0, duration: 0.5 }, 0);
  }

  if (heroBg) {
    gsap.set(heroBg, { height: "100vh" });
    enterTL.to(heroBg, { height: "100%", duration: 1, ease: "power2.out" }, "<");
  }

  if (heroImg) {
    enterTL.fromTo(heroImg, { scale: 1.4 }, { scale: 1.1, duration: 1, ease: "power2.out" }, "<");
  }

  // ─────────────────────────────────────────────────────────────
  // 2. TEXT SPLIT & FADE-IN ANIMATIONS
  // ─────────────────────────────────────────────────────────────

  const splitAndAnimateText = (el, delay = 0) => {
    try {
      SplitText.create(el, {
        type: "lines",
        mask: "lines",
        autoSplit: true,
        reduceWhiteSpace: false,
        linesClass: "line",
        onSplit: (instance) => {
          const lines = instance.lines;
          if (!lines?.length) return;

          gsap.set(el, { visibility: "visible" });
          gsap.set(lines, {
            yPercent: 110,
            rotationX: 50,
            transformOrigin: "left top"
          });

          enterTL.to(
            lines,
            {
              yPercent: 0,
              rotationX: 0,
              duration: 1,
              ease: "expo.out",
              stagger: 0.08
            },
            delay
          );
        }
      });
    } catch (err) {}
  };

  const fadeInElement = (el, delay = 0) => {
    // Ensure element starts visible but transparent
    gsap.set(el, { visibility: "visible", opacity: 0 });

    enterTL.to(el, {
      opacity: 1,
      duration: 0.6,
      ease: "power2.out"
    }, delay);
  };

  document.querySelectorAll("[data-split='load']").forEach((el) => {
    const delay = parseFloat(el.dataset.delay) || 0;
    splitAndAnimateText(el, delay);
  });

  document.querySelectorAll("[data-load='opacity']").forEach((el) => {
    const delay = parseFloat(el.dataset.delay) || 0;
    fadeInElement(el, delay);
  });

  // ─────────────────────────────────────────────────────────────
  // 3. EXECUTE TIMELINE
  // ─────────────────────────────────────────────────────────────

  if (enterTL.getChildren().length > 0) {
    enterTL.play();
  }

  // ─────────────────────────────────────────────────────────────
  // 4. EXIT PAGE TRANSITION
  // ─────────────────────────────────────────────────────────────

  document.querySelectorAll("a[href]").forEach((link) => {
    const href = link.getAttribute("href");
    if (!href || href.startsWith("http") || href.startsWith("#") || href.startsWith("mailto"))
      return;

    link.addEventListener("click", (e) => {
      const targetUrl = link.href;
      const targetPath = new URL(targetUrl).pathname;
      const goingHome = targetPath === "/" || targetPath === "/index.html";
      if (goingHome) return;

      e.preventDefault();
      gsap.set(transition, { autoAlpha: 0 });
      gsap.to(transition, {
        autoAlpha: 1,
        duration: 0.7,
        ease: "power2.inOut",
        onComplete: () => {
          window.location.href = targetUrl;
        }
      });
    });
  });

  initLineAnimations();
}

