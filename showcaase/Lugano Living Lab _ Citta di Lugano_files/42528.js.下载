// Define the class globally
class SVGRadialReveal {
  constructor() {
    this.footerSection = document.querySelector('.section.section--footer');
    this.svgContainer = document.getElementById('svgContainer');
    this.svg = this.svgContainer?.querySelector('.reveal-svg');
    this.revealCircle = document.getElementById('revealCircle');
    this.customCursor = document.getElementById('customCursor');
    this.radialGradient = document.getElementById('revealMask');

    this.mouse = { x: 0, y: 0 };
    this.smoothMouse = { x: 0, y: 0 };
    this.isHovering = false;

    // Check if all required elements exist (cursor is optional)
    if (!this.footerSection || !this.svgContainer || !this.svg ||
      !this.revealCircle || !this.radialGradient) {
      return;
    }

    this.init();
  }

  init() {
    this.setupEventListeners();
    this.animate();
  }

  setupEventListeners() {
    // Mouse move tracking
    document.addEventListener('mousemove', (e) => {
      this.mouse.x = e.clientX;
      this.mouse.y = e.clientY;

      // Update custom cursor position with safety check (optional)
      if (this.customCursor) {
        this.customCursor.style.left = e.clientX - 10 + 'px';
        this.customCursor.style.top = e.clientY - 10 + 'px';
      }
    });

    // Footer section hover detection (entire section as trigger)
    if (this.footerSection) {
      this.footerSection.addEventListener('mouseenter', () => {
        this.isHovering = true;
        // Optional cursor scaling
        if (this.customCursor) {
          this.customCursor.style.transform = 'scale(1.5)';
        }
      });

      this.footerSection.addEventListener('mouseleave', () => {
        this.isHovering = false;
        // Optional cursor scaling
        if (this.customCursor) {
          this.customCursor.style.transform = 'scale(1)';
        }
      });
    }

    // Window resize
    window.addEventListener('resize', () => {
      this.updateMaskPosition();
    });
  }

  updateMaskPosition() {
    if (!this.isHovering || !this.svg || !this.radialGradient || !this.revealCircle) return;

    // Get SVG bounding box for mask calculation
    const svgRect = this.svg.getBoundingClientRect();

    // Convert mouse position to SVG coordinates
    const relativeX = (this.smoothMouse.x - svgRect.left) / svgRect.width;
    const relativeY = (this.smoothMouse.y - svgRect.top) / svgRect.height;

    // Clamp values between 0 and 1
    const clampedX = Math.max(0, Math.min(1, relativeX));
    const clampedY = Math.max(0, Math.min(1, relativeY));

    // Update gradient center
    this.radialGradient.setAttribute('cx', `${clampedX * 100}%`);
    this.radialGradient.setAttribute('cy', `${clampedY * 100}%`);

    // Larger radius with smoother variations for better feathering
    const baseRadius = 45; // Increased for more coverage
    const dynamicRadius = baseRadius + 10; // Smaller variation for consistency
    this.radialGradient.setAttribute('r', `${dynamicRadius}%`);

    // Also update the mask circle for better performance
    const svgWidth = 1182;
    const svgHeight = 1034;
    const circleX = clampedX * svgWidth;
    const circleY = clampedY * svgHeight;

    this.revealCircle.setAttribute('cx', circleX);
    this.revealCircle.setAttribute('cy', circleY);

    // Larger circle radius with consistent size for smooth feathering
    const circleRadius = 320; // Increased to accommodate feather effect
    this.revealCircle.setAttribute('r', circleRadius);
  }

  animate() {
    // Slower mouse movement with enhanced lag for "catching up" feel
    const ease = 0.04; // Reduced from 0.08 for more lag
    this.smoothMouse.x += (this.mouse.x - this.smoothMouse.x) * ease;
    this.smoothMouse.y += (this.mouse.y - this.smoothMouse.y) * ease;

    // Update mask position
    this.updateMaskPosition();

    requestAnimationFrame(() => this.animate());
  }
}

