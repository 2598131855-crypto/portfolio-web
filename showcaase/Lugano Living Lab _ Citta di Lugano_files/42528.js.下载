// ============================================================================
function initColorBlockReveal() {
  document.querySelectorAll('[data-color-reveal]').forEach(container => {
    const grid = container.querySelector('[data-color-grid]');
    const gridSize = 8; // 10×10 grid
    const totalDuration = 0.8; // seconds
    const cells = [];

    if (!grid) {
      return;
    }

    // Determine block color: custom color > theme color > default black
    let blockColor = '#000000'; // Default to black

    // Check for custom block color first
    if (container.dataset.blockColor) {
      blockColor = container.dataset.blockColor;
    } else if (document.body) {
      // Check for theme color from data-colour attribute on body
      const pageTheme = document.body.getAttribute('data-colour');
      if (pageTheme) {
        const themeComputedStyle = getComputedStyle(document.body);
        const themeColor = themeComputedStyle.getPropertyValue('--theme-colour');
        if (themeColor && themeColor.trim() !== '') {
          blockColor = themeColor.trim();
        }
      }
    }

    // Build the solid-colour grid
    const pct = 100 / gridSize;
    for (let row = 0; row < gridSize; row++) {
      for (let col = 0; col < gridSize; col++) {
        const cell = document.createElement('div');

        // Calculate precise positions to avoid gaps
        const left = col * pct;
        const top = row * pct;
        const width = pct;
        const height = pct;

        // Ensure the last row/column extends to fill any gaps
        const isLastRow = row === gridSize - 1;
        const isLastCol = col === gridSize - 1;

        Object.assign(cell.style, {
          position: 'absolute',
          width: isLastCol ? `calc(${width}% + 1px)` : `${width}%`,
          height: isLastRow ? `calc(${height}% + 1px)` : `${height}%`,
          top: `${top}%`,
          left: `${left}%`,
          backgroundColor: blockColor,
          opacity: '1',
          pointerEvents: 'none',
          margin: '0',
          padding: '0',
          border: 'none',
          outline: 'none'
        });
        grid.appendChild(cell);
        cells.push(cell);
      }
    }

    // On scroll-in, fade out each block
    ScrollTrigger.create({
      trigger: container,
      start: 'top 70%',
      once: true,
      onEnter: () => {
        gsap.to(cells, {
          opacity: 0,
          duration: 0,
          stagger: {
            each: totalDuration / cells.length,
            from: 'random'
          },
          onComplete: () => {
            grid.remove();
          }
        });
      }
    });
  });
}

