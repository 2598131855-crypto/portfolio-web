function initDetailsYouTubeThumbnails() {
  // Check if YouTube elements exist
  const youtubeElements = document.querySelectorAll('.youtube');
  if (youtubeElements.length === 0) return;

  youtubeElements.forEach(el => {
    const urlString = el.dataset.embed;
    if (!urlString) return;

    // Parse the URL and grab the "v" parameter
    let videoId;
    try {
      const url = new URL(urlString);
      videoId = url.searchParams.get('v');
    } catch (e) {
      return; // Invalid URL, skip
    }
    if (!videoId) return;

    // Skip if already initialized
    if (el.querySelector('img') || el.querySelector('iframe')) return;

    // 1️⃣  Create & append the thumbnail image
    const thumb = new Image();
    thumb.src = `https://img.youtube.com/vi/${videoId}/sddefault.jpg`;
    thumb.loading = 'eager';
    thumb.alt = 'YouTube video thumbnail';
    el.appendChild(thumb);

    // Fallback if thumbnail fails
    thumb.addEventListener('error', () => {
      thumb.src = 'https://via.placeholder.com/480x360?text=Video+Unavailable';
    });

    // 2️⃣  On click: swap in the YouTube iframe
    el.addEventListener('click', () => {
      const iframe = document.createElement('iframe');
      iframe.setAttribute('frameborder', '0');
      iframe.setAttribute('allowfullscreen', '');
      iframe.src = `https://www.youtube.com/embed/${videoId}?rel=0&showinfo=0&autoplay=1`;

      // Remove thumb + play button, insert player
      el.innerHTML = '';
      el.appendChild(iframe);
    });
  });
}

