function initResponsiveMenu() {
  const trigger = document.querySelector('[data-menu-trigger]');
  const navbar = document.querySelector('.navbar');
  const icon = document.querySelector('.menu__icon');
  const links = document.querySelector('.navbar__links');
  if (!trigger || !navbar || !icon || !links) return;

  let isOpen = false;
  const clickHandler = () => {
    isOpen = !isOpen;
    navbar.classList.toggle('open', isOpen);
    icon.classList.toggle('open', isOpen);
    trigger.setAttribute('aria-expanded', isOpen);
    document.body.style.overflow = isOpen ? 'hidden' : '';
    links.style.pointerEvents = isOpen ? 'auto' : 'none';

    // Pause/resume Lenis
    if (typeof lenis !== 'undefined') {
      if (isOpen) {
        lenis.stop();
      } else {
        lenis.start();
      }
    }
  };

  // MediaQuery for ≤ 991px
  const mql = window.matchMedia('(max-width: 991px)');

  function enable() {
    if (!isOpen) {
      // ensure links are not clickable until open
      links.style.pointerEvents = 'none';
      trigger.setAttribute('aria-expanded', 'false');
    }
    trigger.addEventListener('click', clickHandler);
  }

  function disable() {
    trigger.removeEventListener('click', clickHandler);
    // reset everything to closed state
    if (isOpen) {
      isOpen = false;
      navbar.classList.remove('open');
      icon.classList.remove('open');
      document.body.style.overflow = '';
      links.style.pointerEvents = '';
      trigger.setAttribute('aria-expanded', 'false');

      // Resume Lenis
      if (typeof lenis !== 'undefined') {
        lenis.start();
      }
    }
  }

  // Listen for viewport changes
  mql.addEventListener('change', e => {
    if (e.matches) enable();
    else disable();
  });

  // Initialize based on current width
  if (mql.matches) {
    enable();
  }
}

