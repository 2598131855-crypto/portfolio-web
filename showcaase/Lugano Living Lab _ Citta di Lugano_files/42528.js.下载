function initDetailsAccordion() {
  document.querySelectorAll('[data-accordion]').forEach(section => {
    if (section.dataset.accordionInit === '1') return;

    const listWrapper = section.querySelector('.rich-text__list.rich-text__list--accordion');
    if (!listWrapper) return;

    const listElement = listWrapper.querySelector(':scope > ul') || listWrapper.querySelector(
      'ul');
    if (!listElement) return;

    const sectionIndex = Array.from(document.querySelectorAll('[data-accordion]')).indexOf(
      section);
    const sectionId = section.id || `accordion-section-${sectionIndex + 1}`;
    if (!section.id) {
      section.id = sectionId;
    }

    const lineTemplateEl = Array.from(section.querySelectorAll('.rich-text__list-line')).find(
      el => !el.closest('li'));
    const iconTemplateEl = Array.from(section.querySelectorAll('.rich-text__accordion-icon'))
      .find(el => !el.closest('li'));
    const linkIconTemplateEl = Array.from(section.querySelectorAll(
      '.rich-text__list-link-icon')).find(el => !el.closest('li'));

    const lineHTML = lineTemplateEl ? lineTemplateEl.innerHTML : '';
    const iconHTML = iconTemplateEl ? iconTemplateEl.innerHTML : '';
    const linkIconHTML = linkIconTemplateEl ? linkIconTemplateEl.innerHTML : '';

    if (lineTemplateEl) {
      lineTemplateEl.style.display = 'none';
    }
    if (iconTemplateEl) {
      iconTemplateEl.style.display = 'none';
    }
    if (linkIconTemplateEl) {
      linkIconTemplateEl.style.display = 'none';
    }

    const createLineClone = () => {
      if (lineTemplateEl) {
        const clone = lineTemplateEl.cloneNode(true);
        clone.style.display = '';
        return clone;
      }
      if (!lineHTML) return null;
      const wrapper = document.createElement('div');
      wrapper.className = 'rich-text__list-line';
      wrapper.innerHTML = lineHTML;
      return wrapper;
    };

    const createIconClone = () => {
      if (iconTemplateEl) {
        const clone = iconTemplateEl.cloneNode(true);
        clone.style.display = '';
        return clone;
      }
      if (!iconHTML) return null;
      const iconClone = document.createElement('div');
      iconClone.className = 'rich-text__accordion-icon';
      iconClone.innerHTML = iconHTML;
      return iconClone;
    };

    const createLinkIconClone = () => {
      if (linkIconTemplateEl) {
        const clone = linkIconTemplateEl.cloneNode(true);
        clone.style.display = '';
        return clone;
      }
      if (!linkIconHTML) return null;
      const iconClone = document.createElement('div');
      iconClone.className = 'rich-text__list-link-icon';
      iconClone.innerHTML = linkIconHTML;
      return iconClone;
    };

    const interactiveItems = [];
    const itemMap = new Map();

    Array.from(listElement.children).forEach((node, index) => {
      if (!(node instanceof HTMLElement)) return;
      if (!node.matches('li')) return;

      if (!node.querySelector(':scope > .rich-text__list-line')) {
        const lineClone = createLineClone();
        if (lineClone) {
          node.append(lineClone);
          lineClone.querySelectorAll('.list-line').forEach(line => {
            line.removeAttribute('data-line-animation-bound');
            line.style.transform = '';
            line.style.transformOrigin = '';
          });
        }
      }

      node.querySelectorAll(':scope > .rich-text__list-line .list-line').forEach(line => {
        line.removeAttribute('data-line-animation-bound');
        line.style.transform = '';
        line.style.transformOrigin = '';
      });

      const panel = Array.from(node.children).find(child => child instanceof HTMLElement &&
        child.tagName === 'UL');

      if (!panel) {
        node.removeAttribute('role');
        node.removeAttribute('aria-expanded');
        node.dataset.accordionItem = 'static';
        node.style.cursor = '';

        const isStopNode = candidate => candidate && candidate.nodeType === 1 && (
          candidate.classList.contains('rich-text__list-line') ||
          candidate.classList.contains('rich-text__list-link-icon') ||
          candidate.classList.contains('rich-text__accordion-subtext')
        );

        const ensureSubtextWrapper = beforeNode => {
          let wrapper = node.querySelector(':scope > .rich-text__accordion-subtext');
          if (!wrapper) {
            wrapper = document.createElement('span');
            wrapper.className = 'rich-text__accordion-subtext';
            wrapper.style.cssText =
              'display:block;width:100%;font-size:0.95em;line-height:1.2;color:var(--_color---light--200);';
            node.insertBefore(wrapper, beforeNode || null);
          }
          return wrapper;
        };

        const appendNodesToSubtext = (nodes, beforeNode) => {
          if (!nodes || nodes.length === 0) return;
          const wrapper = ensureSubtextWrapper(beforeNode);
          nodes.forEach(child => wrapper.appendChild(child));
        };

        const anchor = node.querySelector(':scope > a');
        if (anchor) {
          const nodesToWrap = [];

          const anchorBr = anchor.querySelector('br');
          if (anchorBr) {
            let inside = anchorBr.nextSibling;
            while (inside) {
              const nextInside = inside.nextSibling;
              nodesToWrap.push(inside);
              inside = nextInside;
            }
          }

          let sibling = anchor.nextSibling;
          while (sibling && !isStopNode(sibling)) {
            const nextSibling = sibling.nextSibling;
            nodesToWrap.push(sibling);
            sibling = nextSibling;
          }

          appendNodesToSubtext(nodesToWrap, sibling);

          if (!node.querySelector(':scope > .rich-text__list-link-icon')) {
            const linkIconClone = createLinkIconClone();
            if (linkIconClone) {
              node.append(linkIconClone);
            }
          }

          return;
        }

        const directBr = Array.from(node.childNodes).find(child => child.nodeType === 1 &&
          child.tagName === 'BR');
        if (directBr) {
          const nodesToWrap = [];
          let sibling = directBr.nextSibling;
          while (sibling && !isStopNode(sibling)) {
            const nextSibling = sibling.nextSibling;
            nodesToWrap.push(sibling);
            sibling = nextSibling;
          }
          appendNodesToSubtext(nodesToWrap, sibling);
        }

        return;
      }

      if (!node.querySelector(':scope > .rich-text__accordion-icon')) {
        const iconClone = createIconClone();
        if (iconClone) {
          node.insertBefore(iconClone, panel);
        }
      }

      const icon = node.querySelector(':scope > .rich-text__accordion-icon');

      const triggerId = node.id || `${sectionId}__item-${index + 1}`;
      node.id = triggerId;
      const panelId = panel.id || `${triggerId}__panel`;
      panel.id = panelId;

      node.dataset.accordionItem = 'interactive';
      node.setAttribute('role', 'button');
      node.setAttribute('aria-expanded', 'false');
      node.setAttribute('aria-controls', panelId);

      panel.setAttribute('role', 'region');
      panel.setAttribute('aria-labelledby', triggerId);
      panel.setAttribute('aria-hidden', 'true');
      panel.style.maxHeight = '0';
      panel.style.opacity = '0';
      panel.style.overflow = 'hidden';
      if (!panel.style.transition) {
        panel.style.transition = 'max-height 0.4s ease, opacity 0.4s ease';
      }

      node.style.cursor = 'pointer';
      if (icon) {
        icon.classList.remove('open');
      }

      const item = { trigger: node, panel, icon };
      interactiveItems.push(item);
      itemMap.set(node, item);
    });

    if (interactiveItems.length === 0) {
      section.dataset.accordionInit = '1';
      return;
    }

    const closeItem = ({ trigger, panel, icon }) => {
      trigger.setAttribute('aria-expanded', 'false');
      panel.setAttribute('aria-hidden', 'true');
      panel.style.maxHeight = '0';
      panel.style.opacity = '0';
      if (icon) {
        icon.classList.remove('open');
      }
    };

    const openItem = ({ trigger, panel, icon }) => {
      trigger.setAttribute('aria-expanded', 'true');
      panel.setAttribute('aria-hidden', 'false');
      void panel.offsetHeight;
      panel.style.maxHeight = panel.scrollHeight + 'px';
      panel.style.opacity = '1';
      if (icon) {
        icon.classList.add('open');
      }
    };

    listElement.addEventListener('click', (event) => {
      const trigger = event.target.closest('li[data-accordion-item="interactive"]');
      if (!trigger || !listElement.contains(trigger)) return;

      const item = itemMap.get(trigger);
      if (!item) return;

      if (item.panel.contains(event.target)) return;

      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      interactiveItems.forEach(other => {
        if (other !== item) {
          closeItem(other);
        }
      });

      if (isOpen) {
        closeItem(item);
      } else {
        openItem(item);
      }
    });

    section.dataset.accordionInit = '1';
  });

  initLineAnimations();
}

