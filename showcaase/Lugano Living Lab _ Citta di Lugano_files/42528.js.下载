  // Custom arrow navigation - wait for DOM to be ready
  document.addEventListener('DOMContentLoaded', function () {
    // Team slider arrows
    const teamPrevArrow = document.querySelector(
      '[data-slider="slider-team"].slider__arrow--prev');
    const teamNextArrow = document.querySelector(
      '[data-slider="slider-team"].slider__arrow--next');

    if (teamPrevArrow) {
      teamPrevArrow.addEventListener('click', function () {
        if (swiperTeam) swiperTeam.slidePrev();
      });
    }

    if (teamNextArrow) {
      teamNextArrow.addEventListener('click', function () {
        if (swiperTeam) swiperTeam.slideNext();
      });
    }

    // Gallery slider arrows
    const galleryPrevArrow = document.querySelector(
      '[data-slider="slider-gallery"].slider__arrow--prev');
    const galleryNextArrow = document.querySelector(
      '[data-slider="slider-gallery"].slider__arrow--next');

    if (galleryPrevArrow) {
      galleryPrevArrow.addEventListener('click', function () {
        if (swiperGallery) swiperGallery.slidePrev();
      });
    }

    if (galleryNextArrow) {
      galleryNextArrow.addEventListener('click', function () {
        if (swiperGallery) swiperGallery.slideNext();
      });
    }

    // Panels slider arrows
    const panelsPrevArrow = document.querySelector(
      '[data-slider="slider-panels"].slider__arrow--prev');
    const panelsNextArrow = document.querySelector(
      '[data-slider="slider-panels"].slider__arrow--next');

    if (panelsPrevArrow) {
      panelsPrevArrow.addEventListener('click', function () {
        if (swiperPanels) swiperPanels.slidePrev();
      });
    }

    if (panelsNextArrow) {
      panelsNextArrow.addEventListener('click', function () {
        if (swiperPanels) swiperPanels.slideNext();
      });
    }

    // Featured slider arrows
    const featuredPrevArrow = document.querySelector(
      '[data-slider="slider-featured"].slider__arrow--prev');
    const featuredNextArrow = document.querySelector(
      '[data-slider="slider-featured"].slider__arrow--next');

    if (featuredPrevArrow) {
      featuredPrevArrow.addEventListener('click', function () {
        if (swiperFeatured) swiperFeatured.slidePrev();
      });
    }

    if (featuredNextArrow) {
      featuredNextArrow.addEventListener('click', function () {
        if (swiperFeatured) swiperFeatured.slideNext();
      });
    }
  });

  // Check if Swiper is available
  if (typeof Swiper === 'undefined') {
    return;
  }

  // ----------------------------------------
  // Function to update image titles with slide numbers
  // ----------------------------------------
  function updateImageTitles(swiperInstance) {
    if (!swiperInstance) return;

    const sliderId = swiperInstance.el.id;
    // Only update titles for featured and panels sliders
    if (sliderId !== 'slider-featured' && sliderId !== 'slider-panels') {
      return;
    }

    // Get all slides in the current slider
    const slides = swiperInstance.slides;
    slides.forEach((slide, index) => {
      // Find the image-title element within this slide
      const imageTitle = slide.querySelector('.image-title');
      if (imageTitle) {
        let slideNumber;
        // For infinite loop sliders (like featured), use data-swiper-slide-index
        const origIndex = slide.getAttribute('data-swiper-slide-index');
        if (origIndex !== null) {
          // +1 because we want 1-based counting
          slideNumber = parseInt(origIndex, 10) + 1;
        } else {
          // For non-loop sliders (like panels), use array index
          slideNumber = index + 1;
        }
        imageTitle.textContent = slideNumber;
      }
    });
  }

  // Function to add gallery videos as slides
  function addGalleryVideosToSlider(swiperInstance) {
    if (!swiperInstance || !swiperInstance.wrapperEl) return;
    const galleryVideos = document.querySelectorAll(
      '.gallery__video:not(.w-dyn-bind-empty):not(.w-condition-invisible)');
    if (!galleryVideos.length) return; // No videos, do nothing

    galleryVideos.forEach((video) => {
      if (!video) return;
      const slide = document.createElement('div');
      slide.className = 'swiper-slide';
      slide.appendChild(video);
      swiperInstance.wrapperEl.appendChild(slide);
    });

    swiperInstance.update();
    swiperInstance.updateSlides();
    swiperInstance.updateProgress();
    swiperInstance.updateSlidesOffset();
  }

  // Function to add panel videos as slides
  function addPanelVideosToSlider(swiperInstance) {
    if (!swiperInstance || !swiperInstance.wrapperEl) return;
    const panelVideos = document.querySelectorAll(
      '.panel__video:not(.w-dyn-bind-empty):not(.w-condition-invisible)');
    if (!panelVideos.length) return; // No videos, do nothing

    panelVideos.forEach((video) => {
      if (!video) return;
      const slide = document.createElement('div');
      slide.className = 'swiper-slide';
      slide.appendChild(video);
      swiperInstance.wrapperEl.appendChild(slide);
    });

    swiperInstance.update();
    swiperInstance.updateSlides();
    swiperInstance.updateProgress();
    swiperInstance.updateSlidesOffset();
  }

  // Function to update arrow visibility
  function updateArrowVisibility(swiperInstance) {
    if (!swiperInstance) return;

    const sliderId = swiperInstance.el.id;
    const prevArrow = document.querySelector(`[data-slider="${sliderId}"].slider__arrow--prev`);
    const nextArrow = document.querySelector(`[data-slider="${sliderId}"].slider__arrow--next`);

    if (!prevArrow || !nextArrow) return;

    // Always show arrows for looped sliders
    if (swiperInstance.params.loop) {
      prevArrow.classList.remove('slider__arrow--hidden');
      nextArrow.classList.remove('slider__arrow--hidden');
      return;
    }

    // Hide prev arrow if at the beginning
    if (swiperInstance.isBeginning) {
      prevArrow.classList.add('slider__arrow--hidden');
    } else {
      prevArrow.classList.remove('slider__arrow--hidden');
    }

    // Hide next arrow only on the last slide
    if (swiperInstance.isEnd) {
      nextArrow.classList.add('slider__arrow--hidden');
    } else {
      nextArrow.classList.remove('slider__arrow--hidden');
    }
  }
}

