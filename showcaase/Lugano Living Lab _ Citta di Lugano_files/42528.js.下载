// Eventi Details - Modal System
function initEventiModal() {
  function openModal(key) {
    const modal = document.querySelector('.eventi__modal');
    const panels = modal.querySelectorAll('.modal__list-item');
    modal.classList.add('active');
    if (typeof lenis !== 'undefined') lenis.stop();

    panels.forEach(panel => {
      panel.classList.toggle(
        'active-item',
        panel.getAttribute('data-eventi-modal') === key
      );
    });
  }

  function closeModal() {
    const modal = document.querySelector('.eventi__modal');
    const panels = modal.querySelectorAll('.modal__list-item');
    modal.classList.remove('active');
    if (typeof lenis !== 'undefined') lenis.start();

    panels.forEach(panel => panel.classList.remove('active-item'));
  }

  document.querySelectorAll('.item-list__item[data-item]')
    .forEach(item => {
      item.addEventListener('click', () => {
        openModal(item.getAttribute('data-item'));
      });
    });
  document.querySelectorAll('[data-modal-close]')
    .forEach(btn => btn.addEventListener('click', closeModal));
}

// Eventi Details - Date Filter
function initEventiDateFilter() {
  const filterListContainer = document.querySelector('.filter__list-items');
  const itemsContainer = document.querySelector('[data-filter-list]');
  const items = Array.from(document.querySelectorAll('.item-list__item[data-filter-item]'));
  const transitionDelay = 300;

  if (!filterListContainer || !itemsContainer || items.length === 0) return;

  // Set parent list container to display flex to prevent height jumping
  itemsContainer.style.display = 'flex';

  // Remove any hard-coded buttons
  filterListContainer.querySelectorAll('.filter__eventi-list-item').forEach(el => el.remove());

  // Gather & sort unique dates
  const dates = Array.from(new Set(items.map(i => i.dataset.filterItem)))
    .sort((a, b) => {
      const toISO = s => s.split('.').reverse().join('-');
      return new Date(toISO(a)) - new Date(toISO(b));
    });

  function updateStatus(el, isActive) {
    el.setAttribute('data-filter-status', isActive ? 'active' : 'not-active');
    el.setAttribute('aria-hidden', isActive ? 'false' : 'true');
  }

  function makeButton(label) {
    // Find the original template that contains the actual SVG
    // Look for a hidden template or the first instance before we start creating buttons
    const originalTemplate = document.querySelector(
      '.filter__eventi-list-item:not([data-filter-radio])');

    if (originalTemplate) {
      // Clone the original template with the actual SVG
      const btn = originalTemplate.cloneNode(true);
      btn.dataset.filterRadio = label;

      // Find and update the text content
      const textElement = btn.querySelector('.filter__eventi-list-text');
      if (textElement) {
        textElement.textContent = label;
      }

      // Remove any existing active class
      btn.classList.remove('active');

      return btn;
    } else {
      // If no template found, look for the SVG template outside the items
      const templateSvg = document.querySelector('.filter__list > svg.filter__eventi-list-icon');

      const btn = document.createElement('div');
      btn.className = 'filter__eventi-list-item';
      btn.dataset.filterRadio = label;

      const iconContainer = document.createElement('div');
      iconContainer.className = 'filter__eventi-list-icon';

      if (templateSvg) {
        // Clone the existing SVG template
        const svgClone = templateSvg.cloneNode(true);
        iconContainer.appendChild(svgClone);
      } else {
        // Fallback: create the SVG manually
        const svg = document.createElement('svg');
        svg.setAttribute('width', '12');
        svg.setAttribute('height', '11');
        svg.setAttribute('viewBox', '0 0 12 11');
        svg.setAttribute('fill', 'none');
        svg.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
        svg.style.cssText = 'width: 12px; height: 11px; display: block;';
        svg.innerHTML =
          '<path d="M1.33398 5.38737H10.6673M10.6673 5.38737L6.00065 0.720703M10.6673 5.38737L6.00065 10.054" stroke="currentColor" stroke-linecap="square"/>';
        iconContainer.appendChild(svg);
      }

      const textContainer = document.createElement('div');
      textContainer.className = 'filter__eventi-list-text';
      textContainer.textContent = label;

      btn.appendChild(iconContainer);
      btn.appendChild(textContainer);

      return btn;
    }
  }

  dates.forEach(d => filterListContainer.appendChild(makeButton(d)));
  const buttons = Array.from(filterListContainer.querySelectorAll('[data-filter-radio]'));

  function parseDateTime(item) {
    const [day, month, year] = item.dataset.filterItem.split('.').map(Number);
    const [start] = item.dataset.filterTime.split('-');
    const [h, m] = start.split(':').map(Number);
    return new Date(year, month - 1, day, h, m).getTime();
  }

  function sortItems() {
    const sorted = Array.from(itemsContainer.children)
      .sort((a, b) => parseDateTime(a) - parseDateTime(b));
    sorted.forEach(el => itemsContainer.appendChild(el));
  }

  sortItems();

  function applyFilter(activeFilters) {
    items.forEach(item => {
      // If no filters are active, show all items
      const shouldBeActive = activeFilters.length === 0 || activeFilters.includes(item.dataset
        .filterItem);
      const currStatus = item.getAttribute('data-filter-status');

      // Always transition all items - first transition out, then transition to final state
      if (currStatus === 'active') {
        // Item is currently active - transition out first
        item.setAttribute('data-filter-status', 'transition-out');
        item.timeoutId = setTimeout(() => {
          updateStatus(item, shouldBeActive);
          item.timeoutId = null;
        }, transitionDelay);
      } else {
        // Item is currently inactive - transition to final state
        item.timeoutId = setTimeout(() => {
          updateStatus(item, shouldBeActive);
          item.timeoutId = null;
        }, transitionDelay);
      }
    });
    setTimeout(sortItems, transitionDelay);
  }

  // Track active filters
  let activeFilters = [];

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filterValue = btn.dataset.filterRadio;
      const isActive = btn.classList.contains('active');

      if (isActive) {
        // Remove from active filters
        activeFilters = activeFilters.filter(f => f !== filterValue);
        btn.classList.remove('active');
      } else {
        // Add to active filters
        activeFilters.push(filterValue);
        btn.classList.add('active');
      }

      // Apply filter with all active filters
      applyFilter(activeFilters);
    });
  });

  // Initialize with automatic filter activation if only one date
  if (dates.length === 1) {
    // If there's only one date, automatically activate it
    const singleButton = buttons[0];
    if (singleButton) {
      singleButton.classList.add('active');
      activeFilters = [dates[0]];
      applyFilter(activeFilters);
    }
  } else {
    // Initialize with no filters active - show all items
    applyFilter(activeFilters);
  }
}

