function initHomePreloader() {
  const PRELOADER_TIME_SCALE = 0.5;
  const scaleTime = (seconds) => seconds * PRELOADER_TIME_SCALE;

  // ——— 1) Cookie-Script injection logic ———
  function injectCookieScript() {
    var cs = document.createElement('script');
    cs.src = 'https://cdn.cookie-script.com/s/c0d642f420867d7d7aa706e89df6632f.js';
    cs.async = true;
    cs.defer = true;
    document.head.appendChild(cs);
  }

  // If 'preloaderInitialized' isn't set yet, this is first load
  var firstLoad = !sessionStorage.getItem('preloaderInitialized');
  if (firstLoad) {
    // schedule it 6 s out
    setTimeout(injectCookieScript, 6000);
  } else {
    // every later page → inject right away
    injectCookieScript();
  }

  // ——— 2) Your existing preloader logic —— 

  // Only run once per browser session
  if (sessionStorage.getItem('preloaderInitialized')) {
    // Hide preloader if already initialized
    const preloader = document.querySelector(".preloader");
    if (preloader) {
      gsap.set(preloader, {
        opacity: 0,
        visibility: "hidden"
      });
