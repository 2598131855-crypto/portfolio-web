        code: 'KeyA',
        keyCode: 65,
        which: 65,
        bubbles: true,
        cancelable: true
      });
      document.dispatchEvent(keyEvent);
    });

    return;
  }
  sessionStorage.setItem('preloaderInitialized', 'true');

  // Stop Lenis smooth scrolling during preloader
  if (window.lenis) {
    window.lenis.stop();
  }

  const counter3 = document.querySelector(".counter-3");
  if (!counter3) {
    // If we're not on the home page (no preloader elements), restart Lenis immediately
    if (window.lenis) {
      window.lenis.start();
    }
    return;
  }

  // Create counter numbers
  for (let i = 0; i < 2; i++) {
    for (let j = 0; j < 10; j++) {
      const div = document.createElement("div");
