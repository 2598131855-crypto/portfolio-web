      y: "0%",
      stagger: { amount: scaleTime(0.4) },
      duration: scaleTime(0.6),
      delay: scaleTime(2.5), // Before FLIP animation
      ease: "power2.inOut",
    });
  }

  // Animate the preload title using FLIP to target position
  gsap.delayedCall(scaleTime(4), function () {
